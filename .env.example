# Copy to .env at repo root, then: docker compose up -d --build
#
# Backends only in Docker. Frontends: pnpm dev (see README).
#
# Local URLs:
#   Web     http://localhost:3004  (pnpm dev:web)
#   ML Lab  http://localhost:3005  (pnpm dev:ml-lab)
#   API     http://localhost:8088
#   ML API  http://localhost:8000

JWT_SECRET=dev-change-me-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3004
SEED_ADMIN_EMAIL=coordinator@liver.kz
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_DOCTOR_PASSWORD=Doctor123!
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
TRUSTED_PROXY_IPS=127.0.0.1,::1
API_RATE_LIMIT_MAX=120
REFRESH_RATE_LIMIT_MAX=20

AUTH_SECRET=dev-auth-secret-change-me
AUTH_URL=http://localhost:3004

DATABASE_URL=postgres://liver:liver@localhost:5435/liver?sslmode=disable
API_URL=http://localhost:8088
API_PROXY_TARGET=http://localhost:8088

# ML inference (docker internal + allow http in dev)
AI_INFERENCE_URL=http://ml-api:8000/inference
AI_INFERENCE_ALLOW_HTTP=true
AI_INFERENCE_API_KEY=
AI_INFERENCE_TIMEOUT=60s

EXCEL_EXPORT_ENABLED=false
